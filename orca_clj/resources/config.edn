;; Analysis configuration for the Clojure/CmdStan reproduction.
;;
;; This holds the *inputs* a re-run might tweak — file paths, MCMC settings, the
;; orca zone, the ordinal encodings, validation tolerances. Loaded JVM-side via
;; orca.config. Computed metadata (categories, standardization) and the
;; posterior draws are still emitted as JSON (browser-native + the
;; validation oracle speaks JSON).
;;
;; Relative paths resolve against the orca_clj working directory, as before.
{:paths
 {:raw           "../orca_data/all_reports_detailed.json"
  :modeling-csv  "../bayesian_orca/data/modeling_data.csv"
  :metadata-json "../bayesian_orca/data/metadata.json"
  :ref-posterior "../blogpost/posterior_draws.json"
  :out-posterior "out/posterior_draws.json"
  :out-dir       "out"
  :rate-out-dir  "out/rate"}

 :mcmc
 {:seed        42
  :n-chains    4
  :num-warmup  1000
  :num-samples 2000
  :n-out       500}

 ;; Orca zone (methodology.html §7): solar position is evaluated at 37N, 8W.
 :zone {:lat 37.0 :lon -8.0}

 ;; Passages longer than this many hours are data-entry errors (the raw data has
 ;; multi-month "passages") and are dropped from the exposure integration.
 :max-passage-hours 168.0

 ;; Ordinal level -> code.
 :ordinal-maps
 {:boat-length {"Under 10m" 0 "10 - 12.5m" 1 "12.5 - 15m" 2 "Over 15m" 3}
  :depth       {"Up to 20m" 0 "20 - 40m" 1 "40 - 200m" 2 "200m+" 3}
  :distance    {"0 - 2" 0 "2 - 5" 1 "5 - 10" 2 "Over 10" 3}
  :speed       {"0 - 2" 0 "3 - 4" 1 "5 - 7" 2 "8 - 11" 3}
  :wind        {"0 - 2 (0 - 6 knots)" 0 "3 - 4 (7 - 16 knots)" 1
                "5 - 6 (17 - 27 knots)" 2 "7+ (28 knots+)" 3}
  :sea-state   {"Calm" 0 "Moderate" 1 "Rough" 2}
  :cloud-cover {"0 - 25%" 0 "25 - 50%" 1 "50 - 75%" 2 "75 - 100%" 3}}

 ;; Posterior-comparison tolerances for orca.validate/validate-posterior.
 :validate {:abs-tol 0.1 :rel-tol 0.2}

 ;; Cruising Association orca-survey API (orca.fetch). This is a documented JSON
 ;; API, not a scraped site — every record comes from an endpoint below.
 :api
 {:base-url        "https://apinl.theca.org.uk/orcasurvey/v1"
  :client-type     "websiteapp"
  :out-dir         "../orca_data"
  :max-workers     15
  :retries         3
  :timeout-seconds 120
  ;; Column orderings for the emitted CSVs (present keys first in this order,
  ;; then any remaining keys alphabetically — matches the original downloader).
  :summary-priority [:report_id :type :serial :time :lat :long]
  :incident-priority
  [:report_id :serial :report_type :date_of_interaction :time_of_interaction
   :summary_lat :summary_long :summary_time
   :lat_deg :lat_min :long_deg :long_min
   :boat_type :boat_length :motoring_or_sailing :speed
   :rudder :autopilot :antifoul_colour :hull_topsides_colour
   :depth :distance_off_land :sea_state :wind_speed
   :darkness_or_daylight :cloud_cover
   :damaged :tow_required :length_of_interaction
   :behaviour_text_edited :response_text_edited
   :towing :depth_gauge :daystage :moon :tide]
  :uneventful-priority
  [:report_id :serial :report_type :summary_time
   :summary_lat :summary_long
   :boat_type :boat_length :motoring_or_sailing :speed
   :rudder :autopilot :antifoul_colour :hull_topsides_colour
   :depth :distance_off_land :sea_state :wind_speed]}}
